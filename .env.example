# Agent Bus Hub
HUB_URL=http://localhost:4000
PORT=4000
LOG_DIR=data

# Claw3D Inject Endpoint (adapter → Claw3D)
INJECT_SECRET=your-shared-secret-here
CLAW3D_INJECT_URL=http://localhost:3000/api/inject-event

# Cloudflare Access (for remote producers via CF tunnel)
CF_CLIENT_ID=
CF_CLIENT_SECRET=

# Remote hub URL (uncomment when using CF tunnel)
# HUB_URL=https://agent-bus.yourdomain.com

# Agent identity (for hook scripts)
AGENT_BUS_AGENT=
AGENT_BUS_PROJECT=
