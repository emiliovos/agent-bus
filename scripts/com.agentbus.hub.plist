<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Agent Bus Hub — macOS LaunchAgent
  Auto-starts the hub (:4000) on login.

  Setup:
    1. Edit the three placeholder values below:
         /path/to/agent-bus  →  absolute path to your agent-bus repo
         /usr/local/bin/node →  output of: which node
         /Users/<yourname>   →  your home directory (or use /Users/Shared for shared installs)

    2. Copy to LaunchAgents:
         cp scripts/com.agentbus.hub.plist ~/Library/LaunchAgents/

    3. Load:
         launchctl load ~/Library/LaunchAgents/com.agentbus.hub.plist

    4. Verify:
         launchctl list | grep agentbus
         curl http://localhost:4000/health

  Unload:
    launchctl unload ~/Library/LaunchAgents/com.agentbus.hub.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agentbus.hub</string>

  <key>ProgramArguments</key>
  <array>
    <!-- Replace with: which node -->
    <string>/usr/local/bin/node</string>
    <!-- Replace with: absolute path to agent-bus/dist/index.js -->
    <string>/path/to/agent-bus/dist/index.js</string>
  </array>

  <!-- Working directory — must match repo root so data/ log is written correctly -->
  <key>WorkingDirectory</key>
  <string>/path/to/agent-bus</string>

  <!-- Environment variables — adjust as needed -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PORT</key>
    <string>4000</string>
    <key>LOG_DIR</key>
    <string>data</string>
    <key>NODE_ENV</key>
    <string>production</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <!-- Replace /Users/<yourname> with your actual home directory -->
  <key>StandardOutPath</key>
  <string>/Users/<yourname>/Library/Logs/com.agentbus.hub.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/<yourname>/Library/Logs/com.agentbus.hub.log</string>
</dict>
</plist>
